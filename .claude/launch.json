{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "bot-dev",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--config", "bot/vite.config.js", "--port", "3000", "--host"],
      "port": 3000
    },
    {
      "name": "wiki",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "wiki", "run", "dev"],
      "port": 3002
    },
    {
      "name": "assets-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "shared/public/assets", "-p", "8092", "--cors", "-c-1"],
      "port": 8092
    }
  ]
}
